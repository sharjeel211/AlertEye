# ── Web portal API ──────────────────────────────────
# Must match DESKTOP_API_SECRET in the web app's .env (leave blank if unset).
DESKTOP_API_SECRET=

# ── Firebase Realtime Database (per-account alerts for the Android app) ──
# Path to your Firebase service account JSON. If unset/missing, Firebase
# alerts are silently disabled and the app runs normally.
# Download this from Firebase Console > Project Settings > Service Accounts
# > Generate new private key. NEVER commit the real JSON file to git.
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-adminsdk.json
