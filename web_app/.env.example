# ── Flask ──────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string

# ── Database (MySQL) ────────────────────────────────
# Format: mysql+pymysql://USER:PASSWORD@HOST/DBNAME
#
# Local (your machine — create the DB once):
#   CREATE DATABASE alerteye CHARACTER SET utf8mb4;
DATABASE_URL=mysql+pymysql://root:password@localhost/alerteye
#
# Namecheap (cPanel > MySQL Databases creates the DB/user; names are prefixed
# with your cPanel account, e.g. cpaneluser_alerteye / cpaneluser_dbuser):
#   DATABASE_URL=mysql+pymysql://cpaneluser_dbuser:PASSWORD@localhost/cpaneluser_alerteye

# ── Email (Gmail) ───────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
# Use a Gmail App Password, not your real password:
# https://myaccount.google.com/apppasswords
MAIL_PASSWORD=

# ── Stripe (TEST mode) ──────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# Optional: signing secret if you wire up the Stripe webhook (whsec_...)
STRIPE_WEBHOOK_SECRET=

# Currency + prices (in major units, e.g. dollars). Plan -> price.
PAYMENT_CURRENCY=usd
PRICE_MONTHLY=0
PRICE_QUARTERLY=0
PRICE_YEARLY=0

# Public base URL used to build Stripe success/cancel return links
PUBLIC_BASE_URL=http://localhost:5000

# Company info shown on the PDF invoice
COMPANY_NAME=
COMPANY_ADDRESS=
COMPANY_EMAIL=

# ── Mobile alerts (ntfy) ────────────────────────────
# Push notifications + ring are handled by the DESKTOP app via ntfy.
# Configure NTFY_SERVER / NTFY_TOPIC in desktop_app/.env (or in-app Settings).

# ── Desktop App ─────────────────────────────────────
APP_DOWNLOAD_URL=
DESKTOP_API_SECRET=

# ── Website assistant (OpenRouter) ──────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_FALLBACK_MODEL=
